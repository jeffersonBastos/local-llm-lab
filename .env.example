# Copy to .env and fill in. .env is gitignored — never commit real values.

# LAN address of the machine running LM Studio's server
LLM_HOST=192.168.x.x
LLM_PORT=1234

# Model id as reported by GET /v1/models (leave empty to auto-detect first loaded model)
LLM_MODEL=

# Dummy token — LM Studio doesn't check auth, but Claude Code requires one to be set
LLM_AUTH_TOKEN=lmstudio
